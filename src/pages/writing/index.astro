---
import BlogList from "@/components/BlogList.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPageCount, getPagePosts, sortPosts } from "@/utils/blog";
import { getCollection } from "astro:content";

const posts = sortPosts(await getCollection("blog", ({ data }) => !data.draft));
const currentPage = 1;
const totalPages = getPageCount(posts.length);
const pagePosts = getPagePosts(posts, currentPage);
---

<BaseLayout
  title="Writing"
  description="Technical writing from Michael Porter on backend systems, AI workflow automation, and software engineering."
>
  <section class="page-intro">
    <p class="eyebrow">Writing</p>
    <h1>Technical notes and essays.</h1>
    <p>
      Posts on practical lessons from backend systems, automation, AI-assisted workflows, and
      the occasional sharp edge found while building.
    </p>
  </section>

  <BlogList posts={pagePosts} currentPage={currentPage} totalPages={totalPages} />
</BaseLayout>
