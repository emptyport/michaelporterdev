---
import WorkCard from "@/components/WorkCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { metrics, workHighlights } from "@/data/work";
import { formatDate } from "@/utils/date";
import { postSlug } from "@/utils/postSlug";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="hero">
    <div>
      <p class="eyebrow">Software developer</p>
      <h1>Senior backend engineer building AI tools and automation.</h1>
      <p class="hero-copy">
        I build APIs, data systems, and internal platforms that reduce manual work and help teams move
        faster. Recent work includes multi-agent workflows, developer tooling, and production backend
        systems in TypeScript, Python, PostgreSQL, and AWS.
      </p>
      <div class="action-row">
        <a class="button primary" href="/work/">View work</a>
        <a class="button" href="/writing/">Read writing</a>
      </div>
    </div>
    <aside class="signal-panel" aria-label="Technical strengths">
      <p>Technical strengths</p>
      <ul>
        <li>AI workflow automation</li>
        <li>Backend API platforms</li>
        <li>Developer tools</li>
        <li>Data pipelines</li>
      </ul>
    </aside>
  </section>

  <section class="metric-grid" aria-label="Selected impact metrics">
    {metrics.map((metric) => (
      <div>
        <strong>{metric.value}</strong>
        <span>{metric.label}</span>
      </div>
    ))}
  </section>

  <section class="section-heading">
    <p class="eyebrow">Selected work</p>
    <h2>Business problems solved with software.</h2>
    <p>
      Highlights from recent roles, with the impact, technical scope, and business value of each project.
    </p>
  </section>

  <section class="work-grid">
    {workHighlights.slice(0, 3).map((item) => <WorkCard item={item} />)}
  </section>

  <section class="split-section">
    <div>
      <p class="eyebrow">Writing</p>
      <h2>Writing on practical software engineering.</h2>
      <p>
        Short technical posts on backend systems, AI-assisted development, automation, and lessons from
        building production software.
      </p>
    </div>
    <div class="post-list">
      {posts.map((post) => (
        <a href={`/writing/${postSlug(post.id)}/`}>
          <span>{formatDate(post.data.pubDate, { month: "short", day: "numeric", year: "numeric" })}</span>
          <strong>{post.data.title}</strong>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
