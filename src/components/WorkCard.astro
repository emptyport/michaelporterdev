---
import type { WorkHighlight } from "@/data/work";

type Props = { item: WorkHighlight };

const { item } = Astro.props;
---

<article class="work-card">
  <p class="eyebrow">{item.eyebrow}</p>
  <h3>{item.title}</h3>
  <p>{item.summary}</p>
  <ul class="impact-list">
    {item.impact.map((impact) => (
      <li>
        <strong>{impact.value}</strong>
        <span>{impact.label}</span>
      </li>
    ))}
  </ul>
  <div class="tag-list" aria-label={`Technologies used for ${item.title}`}>
    {item.stack.map((tag) => <span>{tag}</span>)}
  </div>
</article>
